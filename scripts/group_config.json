{
  "base_config": {
    "backend": "tensorflow",
    "compute_device": "gpu",
    "x_scaler": "standard",
    "y_scaler": "standard",
    "causes": ["x1", "x2"],
    "effects": ["y"],
    "tested_causes": ["x1", "x2"],
    "lag_config": {
      "max_lag": 8,
      "use_lag_zero": false
    },
    "lag_selector": {
      "type": "ic",
      "use_bic": true
    },
    "relations": "./group_relations.json",
    "callbacks": [
      {
        "type": "early_stopping",
        "monitor": "loss",
        "patience": 10,
        "min_delta": 0.0,
        "restore_best_weights": true
      },
      {
        "type": "reduce_lr_on_plateau",
        "monitor": "loss",
        "factor": 0.5,
        "patience": 5,
        "min_lr": 1e-06
      }
    ],
    "regularizer": {
      "type": "l1",
      "l1": 0.001
    },
    "model_config": {
      "epochs": 50,
      "batch_size": 32,
      "optimizer": "adam",
      "learning_rate": 0.001
    }
  },
  "sweep": {
    "param_names": [
      "model_config.optimizer",
      "model_config.learning_rate",
      "model_config.epochs",
      "lag_config.max_lag"
    ],
    "cases": [
      ["adam", 0.001, 5, 8],
      ["adam", 0.0005, 5, 10],
      ["adam", 0.0002, 5, 12]
    ]
  }
}
