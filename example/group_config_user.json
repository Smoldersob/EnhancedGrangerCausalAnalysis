{
  "base_config": {
    "backend": "scikit-learn",
    "compute_device": "cpu",
    "x_scaler": "standard",
    "y_scaler": "standard",
    "causes": ["x1", "x2", "u1", "e1", "u", "f1", "f2"],
    "effects": ["x1", "x2", "u1", "e1", "u", "f1", "f2"],
    "tested_causes": ["x1", "x2", "u1", "e1", "u", "f1", "f2"],
    "lag_config": {"max_lag": 6, "use_lag_zero": false},
    "lag_selector": {"type": "ic", "use_bic": true},
    "relations": "./example/group_relations_user.json",
    "callbacks": [
      {"type": "early_stopping", "patience": 10, "min_delta": 0.0, "restore_best_weights": true},
      {"type": "reduce_lr_on_plateau", "factor": 0.5, "patience": 5, "min_lr": 1e-06}
    ],
    "initializer": "OLSInitializer",
    "model_config": {"learning_rate": 0.001, "batch_size": 32, "epochs": 50}
  },
  "sweep": {
    "param_names": ["model_config.learning_rate", "model_config.batch_size"],
    "cases": [
      [0.001, 32],
      [0.001, 64],
      [0.001, null],
      [0.0001, 32],
      [0.0001, 64],
      [0.0001, null],
      [0.00001, 32],
      [0.00001, 64],
      [0.00001, null]
    ]
  }
}
